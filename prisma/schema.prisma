generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

model User {
  id              String            @id @default(cuid())
  walletAddress   String            @unique
  referrerId      String?
  binaryParentId  String?
  binarySide      String?
  referralCode    String            @unique
  isAdmin         Boolean           @default(false)
  totalStaked     Float             @default(0)
  totalEarned     Float             @default(0)
  totalWithdrawn  Float             @default(0)
  leftVolume      Float             @default(0)
  rightVolume     Float             @default(0)
  isActive        Boolean           @default(false)
  xp              Int               @default(0)
  level           Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  referrer        User?             @relation("UnilevelTree", fields: [referrerId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  referrals       User[]            @relation("UnilevelTree")
  stakes          Stake[]
  commissions     Commission[]      @relation("UserCommissions")
  commissionsFrom Commission[]      @relation("CommissionFromUser")
  transactions    Transaction[]
  binaryChildren  User[]            @relation("BinaryTree")
  binaryParent    User?             @relation("BinaryTree", fields: [binaryParentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  achievements    UserAchievement[]
}

model StakingPlan {
  id                   String   @id @default(cuid())
  name                 String
  description          String   @default("")
  durationDays         Int
  apy                  Float
  minAmount            Float
  maxAmount            Float
  isActive             Boolean  @default(true)
  earlyWithdrawPenalty Float    @default(10)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  stakes               Stake[]
}

model Stake {
  id             String      @id @default(cuid())
  userId         String
  planId         String
  amount         Float
  rewardsEarned  Float       @default(0)
  rewardsClaimed Float       @default(0)
  startDate      DateTime
  endDate        DateTime
  status         String      @default("active")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  plan           StakingPlan @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Restrict)
}

model UnilevelConfig {
  id         String   @id @default(cuid())
  level      Int      @unique
  percentage Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BinaryConfig {
  id                String   @id @default(cuid())
  percentage        Float
  dailyCap          Float    @default(0)
  flushOutThreshold Float    @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Commission {
  id          String   @id @default(cuid())
  userId      String
  fromUserId  String
  amount      Float
  type        String
  level       Int      @default(0)
  status      String   @default("pending")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserCommissions", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  fromUser    User     @relation("CommissionFromUser", fields: [fromUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  stakeId     String?
  type        String
  amount      Float
  status      String   @default("completed")
  txHash      String?
  description String   @default("")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String   @default("")
  updatedAt   DateTime @updatedAt
}

model Achievement {
  id               String            @id @default(cuid())
  key              String            @unique
  nameEn           String
  nameEs           String
  namePt           String
  descEn           String
  descEs           String
  descPt           String
  icon             String            @default("Trophy")
  condition        String            @default("{}")
  reward           String            @default("{}")
  tier             String            @default("bronze")
  xpReward         Int               @default(10)
  isActive         Boolean           @default(true)
  order            Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  claimed       Boolean     @default(false)
  claimedAt     DateTime?
  user          User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([userId, achievementId])
}

model Translation {
  id        String   @id @default(cuid())
  key       String
  locale    String
  value     String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  type      String   @unique
  titleEn   String
  titleEs   String
  titlePt   String
  messageEn String
  messageEs String
  messagePt String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
